/* Cyberpunk — Neon yellow/cyan on dark, adapted for Anvil Organizer */

* {
  background: #0A0A12;
  font-size: 13px;
  color: #E0E0E0;
  border: 0; }
  *:disabled {
    color: #4A4A5A; }

QAbstractItemView {
  background: #12121E;
  alternate-background-color: #0A0A12;
  show-decoration-selected: 1;
  border-radius: 6px; }
  QAbstractItemView::item {
    min-height: 24px; }
  QAbstractItemView::branch:hover, QAbstractItemView::item:hover {
    background: #1A1A2E; }
  QAbstractItemView::branch:selected, QAbstractItemView::item:selected {
    background: #FCE300;
    color: #0A0A12; }

QTreeView, QListView {
  border-radius: 6px; }

QHeaderView::up-arrow, QHeaderView::down-arrow {
  height: 10px;
  width: 10px;
  padding-right: 4px; }

QHeaderView::section {
  background: #12121E;
  padding: 0 5px;
  border: 0;
  border-bottom: 2px solid #0A0A12;
  border-right: 2px solid #0A0A12; }
  QHeaderView::section:first {
    border-top-left-radius: 6px; }
  QHeaderView::section:last {
    border-right: 0;
    border-top-right-radius: 6px; }
  QHeaderView::section:hover {
    background: #1A1A2E; }

QScrollBar {
  background: #12121E;
  border: 2px solid #0A0A12; }
  QScrollBar:horizontal {
    height: 20px;
    margin: 0 23px -2px 23px; }
  QScrollBar:vertical {
    width: 20px;
    margin: 23px -2px 23px 0; }
  QScrollBar::handle {
    background: #2A2A3E;
    border-radius: 6px;
    margin: 2px; }
    QScrollBar::handle:horizontal {
      min-width: 32px; }
    QScrollBar::handle:vertical {
      min-height: 32px; }
    QScrollBar::handle:hover, QScrollBar::handle:pressed {
      background: #00F0FF; }
  QScrollBar::add-line {
    subcontrol-origin: margin;
    background: #12121E;
    border: 2px solid #0A0A12;
    margin: 0 -2px -2px 0; }
    QScrollBar::add-line:horizontal {
      width: 23px;
      subcontrol-position: right; }
    QScrollBar::add-line:vertical {
      height: 23px;
      subcontrol-position: bottom;
      border-bottom-right-radius: 6px; }
    QScrollBar::add-line:hover, QScrollBar::add-line:pressed {
      background: #00F0FF; }
  QScrollBar::sub-line {
    subcontrol-origin: margin;
    background: #12121E; }
    QScrollBar::sub-line:horizontal {
      width: 23px;
      subcontrol-position: left;
      border: 2px solid #0A0A12;
      border-bottom-left-radius: 6px;
      margin: 0 0 -2px -2px; }
    QScrollBar::sub-line:vertical {
      height: 23px;
      subcontrol-position: top;
      border: 2px solid #0A0A12;
      border-top-right-radius: 6px;
      margin: -2px -2px 0 0; }
    QScrollBar::sub-line:hover, QScrollBar::sub-line:pressed {
      background: #00F0FF; }
  QScrollBar::add-page, QScrollBar::sub-page {
    background: transparent; }

QPushButton, QToolButton {
  background: #1A1A2E;
  color: #E0E0E0;
  min-height: 22px;
  padding: 2px 12px;
  border-radius: 6px;
  margin: 2px 0; }
  QPushButton:hover, QPushButton:pressed, QToolButton:hover, QToolButton:pressed {
    background: #2A2A3E; }
  QPushButton:disabled, QToolButton:disabled {
    background: transparent; }

QPushButton:disabled {
  background: none;
  border: 2px solid #1A1A2E; }

QMenu {
  background: #12121E;
  border: 2px solid #1A1A2E;
  border-radius: 6px;
  min-width: 180px;
  font-size: 14px; }
  QMenu::separator {
    height: 2px;
    background: #FCE300; }
  QMenu::icon {
    padding-left: 20px; }
  QMenu::item {
    background: #12121E;
    padding: 8px 30px; }
    QMenu::item:disabled {
      background: #0A0A12;
      color: #4A4A5A; }
    QMenu::item:selected {
      background: #FCE300;
      color: #0A0A12;
      border-radius: 6px; }

QToolBar {
  background: #0A0A12;
  border: none;
  border-bottom: 1px solid #FCE300;
  spacing: 2px;
  padding: 4px 8px; }
  QToolBar::separator {
    background: #2A2A3E;
    width: 1px;
    margin: 8px 4px; }
  QToolBar QToolButton {
    background: transparent;
    padding: 6px;
    border-radius: 10px;
    margin: 4px 4px 0 4px; }
    QToolBar QToolButton:hover, QToolBar QToolButton:pressed {
      background: #1A1A2E; }

QLineEdit {
  background: #12121E;
  min-height: 22px;
  padding-left: 5px;
  border: 2px solid #1A1A2E;
  border-radius: 6px; }
  QLineEdit:hover {
    border: 2px solid #00F0FF; }

QComboBox {
  background: #12121E;
  min-height: 22px;
  padding-left: 5px;
  border: 2px solid #1A1A2E;
  border-radius: 6px;
  margin: 4px 0;
  combobox-popup: 0; }
  QComboBox QAbstractItemView {
    background: #12121E;
    border: 2px solid #1A1A2E;
    border-radius: 6px; }
  QComboBox:hover {
    border: 2px solid #00F0FF; }
  QComboBox:on {
    background: #FCE300;
    color: #0A0A12;
    border: 2px solid #FCE300; }
  QComboBox::drop-down {
    width: 20px;
    subcontrol-origin: padding;
    subcontrol-position: top right;
    border: none; }

QGroupBox {
  padding: 24px 4px;
  border: 2px solid #1A1A2E;
  border-radius: 10px; }
  QGroupBox::title {
    background: transparent;
    subcontrol-origin: padding;
    subcontrol-position: top left;
    padding: 8px; }

QProgressBar {
  background: #12121E;
  color: #E0E0E0;
  text-align: center;
  border: 2px solid #0A0A12;
  border-radius: 6px;
  margin: 0 10px; }
  QProgressBar::chunk {
    background: #00F0FF;
    border-top-left-radius: 6px;
    border-bottom-left-radius: 6px; }

QTabWidget::pane {
  bottom: 4px;
  border-radius: 10px; }

QTabWidget::tab-bar {
  alignment: center; }

QTabBar {
  background: #12121E;
  border-radius: 10px; }
  QTabBar QToolButton {
    background: #2A2A3E;
    padding: 1px;
    border-radius: 6px;
    margin: 1px; }
    QTabBar QToolButton:disabled {
      background: transparent; }
  QTabBar::tab {
    background: #12121E;
    padding: 2px 14px;
    border: 2px solid #12121E;
    border-radius: 10px;
    margin: 2px; }
    QTabBar::tab:disabled {
      background: #0A0A12;
      border: 2px solid transparent; }
    QTabBar::tab:first {
      border-top-left-radius: 10px;
      border-bottom-left-radius: 10px; }
    QTabBar::tab:last {
      border-top-right-radius: 10px;
      border-bottom-right-radius: 10px; }
    QTabBar::tab:hover {
      background: #1A1A2E;
      border: 2px solid #1A1A2E; }
    QTabBar::tab:selected {
      background: #FCE300;
      color: #0A0A12;
      border: 2px solid #FCE300; }

QStatusBar {
  background: #12121E; }
  QStatusBar QWidget {
    background: #12121E; }
  QStatusBar::item {
    border: 0; }

QTableView {
  gridline-color: #0A0A12;
  border: 0; }
  QTableView QTableCornerButton::section {
    background: #12121E;
    border: 0;
    border-right: 2px solid #0A0A12;
    border-bottom: 2px solid #0A0A12; }

QAbstractScrollArea::corner {
  background: #12121E;
  border: 2px solid #0A0A12;
  border-bottom-right-radius: 6px;
  margin: 0 -2px -2px 0; }

QMenuBar::item:selected {
  background: #FCE300;
  color: #0A0A12; }

QTextEdit {
  background: #12121E;
  border-radius: 6px; }

QSplitter {
  width: 6px; }

QCheckBox::indicator, QGroupBox::indicator, QRadioButton::indicator {
  width: 14px;
  height: 14px; }

QSpinBox, QDoubleSpinBox {
  min-height: 24px;
  min-width: 60px;
  background: #12121E;
  padding: 0 2px;
  border: 2px solid #1A1A2E;
  border-radius: 6px;
  margin: 0 -4px; }
  QSpinBox::up-button, QSpinBox::down-button, QDoubleSpinBox::up-button, QDoubleSpinBox::down-button {
    min-height: 28px;
    min-width: 20px;
    border: 2px solid #1A1A2E; }
    QSpinBox::up-button:hover, QSpinBox::down-button:hover, QDoubleSpinBox::up-button:hover, QDoubleSpinBox::down-button:hover {
      background: #2A2A3E; }
  QSpinBox::up-button, QDoubleSpinBox::up-button {
    subcontrol-position: center right;
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px; }
  QSpinBox::down-button, QDoubleSpinBox::down-button {
    subcontrol-position: center left;
    border-top-left-radius: 6px;
    border-bottom-left-radius: 6px; }

QSlider::groove {
  height: 0;
  border: 1px solid #2A2A3E; }

QSlider::handle {
  background: #12121E;
  border: 2px solid #00F0FF;
  border-radius: 6px;
  margin: -10px; }
  QSlider::handle:hover {
    background: #1A1A2E; }

QToolTip {
  background: #12121E;
  color: #FCE300;
  border: 2px solid #FCE300;
  border-radius: 6px; }

QLabel {
  color: #E0E0E0; }

/* ── Anvil Organizer specific ──────────────────────────────── */

#activeCount {
  background: #FCE300;
  color: #0A0A12;
  padding: 2px 10px;
  border-radius: 6px; }

#profileBar {
  background: #12121E; }

#gamePanel {
  background: #12121E; }

#startButton {
  background: #FCE300;
  color: #0A0A12;
  padding: 8px 16px;
  font-weight: bold;
  border-radius: 6px; }
  #startButton:hover {
    background: #FFE94D; }
  #startButton:pressed {
    background: #D4BE00; }

#InfoDialog {
  min-width: 750px;
  min-height: 600px; }

#InfoDialog QTextEdit {
  font-size: 15px;
  font-family: monospace; }

/* ── QMessageBox ───────────────────────────────────────── */

QMessageBox {
  background: #0A0A12; }

QMessageBox QLabel {
  color: #E0E0E0;
  font-size: 13px;
  background: transparent; }

QMessageBox QPushButton {
  background: #1A1A2E;
  color: #E0E0E0;
  border: 2px solid #2A2A3E;
  border-radius: 6px;
  padding: 6px 20px;
  font-size: 13px;
  min-width: 80px;
  qproperty-icon: none; }
  QMessageBox QPushButton:hover {
    background: #2A2A3E; }
  QMessageBox QPushButton:default {
    border-color: #FCE300;
    background: #FCE300;
    color: #0A0A12; }

/* ── FilterPanel ──────────────────────────────────────── */

#filterPanel {
  background: #12121E;
  border-right: 2px solid #FCE300;
  border-radius: 0; }

#filterChip {
  background: #0A0A12;
  color: #E0E0E0;
  border: 2px solid #2A2A3E;
  border-radius: 12px;
  padding: 2px 10px;
  font-size: 11px; }
  #filterChip:hover {
    background: #1A1A2E;
    border-color: #00F0FF; }
  #filterChip:checked {
    background: #FCE300;
    color: #0A0A12;
    border-color: #FCE300; }
  #filterChip:checked:hover {
    background: #FFE94D;
    border-color: #FFE94D; }

#filterToggleBar {
  background: #0A0A12;
  border-right: 1px solid #1A1A2E;
  border-radius: 0; }
  #filterToggleBar:hover {
    background: #1A1A2E; }

#filterResetBtn, #filterManageBtn, #filterNexusLoadBtn {
  background: #0A0A12;
  border: 2px solid #2A2A3E;
  border-radius: 6px;
  padding: 4px 12px; }
  #filterResetBtn:hover, #filterManageBtn:hover, #filterNexusLoadBtn:hover {
    background: #1A1A2E; }

/* ── Game Lock Overlay ───────────────────────────────────── */

#game_lock_overlay {
  border: 2px solid #FCE300;
  border-radius: 8px; }

/* ── FOMOD Installer Dialog ──────────────────────────────── */

#fomodStepLabel {
  font-size: 13px;
  font-weight: bold;
  color: #FCE300; }

#fomodPreviewImage {
  background: #0A0A12;
  border: 1px solid #2A2A3E;
  border-radius: 3px; }

#fomodPreviewDesc {
  padding: 8px;
  color: #00F0FF; }

/* ── QFileDialog ──────────────────────────────────────── */
QFileDialog QToolBar QToolButton {
  icon-size: 22px;
  min-width: 28px;
  min-height: 28px; }
QFileDialog QToolBar {
  icon-size: 22px; }
QFileDialog QToolButton {
  icon-size: 22px;
  min-width: 28px;
  min-height: 28px; }
