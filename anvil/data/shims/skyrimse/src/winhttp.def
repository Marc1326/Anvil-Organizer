LIBRARY winhttp.dll
EXPORTS
    WinHttpAddRequestHeaders          = proxy_WinHttpAddRequestHeaders
    WinHttpCheckPlatform              = proxy_WinHttpCheckPlatform
    WinHttpCloseHandle                = proxy_WinHttpCloseHandle
    WinHttpConnect                    = proxy_WinHttpConnect
    WinHttpCrackUrl                   = proxy_WinHttpCrackUrl
    WinHttpCreateProxyResolver        = proxy_WinHttpCreateProxyResolver
    WinHttpCreateUrl                  = proxy_WinHttpCreateUrl
    WinHttpDetectAutoProxyConfigUrl   = proxy_WinHttpDetectAutoProxyConfigUrl
    WinHttpFreeProxyResult            = proxy_WinHttpFreeProxyResult
    WinHttpGetDefaultProxyConfiguration = proxy_WinHttpGetDefaultProxyConfiguration
    WinHttpGetIEProxyConfigForCurrentUser = proxy_WinHttpGetIEProxyConfigForCurrentUser
    WinHttpGetProxyForUrl             = proxy_WinHttpGetProxyForUrl
    WinHttpGetProxyForUrlEx           = proxy_WinHttpGetProxyForUrlEx
    WinHttpGetProxyResult             = proxy_WinHttpGetProxyResult
    WinHttpOpen                       = proxy_WinHttpOpen
    WinHttpOpenRequest                = proxy_WinHttpOpenRequest
    WinHttpQueryAuthSchemes           = proxy_WinHttpQueryAuthSchemes
    WinHttpQueryDataAvailable         = proxy_WinHttpQueryDataAvailable
    WinHttpQueryHeaders               = proxy_WinHttpQueryHeaders
    WinHttpQueryOption                = proxy_WinHttpQueryOption
    WinHttpReadData                   = proxy_WinHttpReadData
    WinHttpReceiveResponse            = proxy_WinHttpReceiveResponse
    WinHttpResetAutoProxy             = proxy_WinHttpResetAutoProxy
    WinHttpSendRequest                = proxy_WinHttpSendRequest
    WinHttpSetCredentials             = proxy_WinHttpSetCredentials
    WinHttpSetDefaultProxyConfiguration = proxy_WinHttpSetDefaultProxyConfiguration
    WinHttpSetOption                  = proxy_WinHttpSetOption
    WinHttpSetStatusCallback          = proxy_WinHttpSetStatusCallback
    WinHttpSetTimeouts                = proxy_WinHttpSetTimeouts
    WinHttpTimeFromSystemTime         = proxy_WinHttpTimeFromSystemTime
    WinHttpTimeToSystemTime           = proxy_WinHttpTimeToSystemTime
    WinHttpWriteData                  = proxy_WinHttpWriteData
